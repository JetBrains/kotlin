                }
                14 [label="Function call enter: Q|kotlin/collections|.R|kotlin/collections/setOf|<R|kotlin/Int|>(...)"];
                15 [label="Function call exit: Q|kotlin/collections|.R|kotlin/collections/setOf|<R|kotlin/Int|>(...)" style="filled" fillcolor=yellow];
                16 [label="Function call arguments exit"];
            }
            17 [label="Function call enter: R|/foo|(...)"];
            18 [label="Function call exit: R|/foo|(...)" style="filled" fillcolor=yellow];
            19 [label="Exit block"];
        }
        20 [label="Exit function test" style="filled" fillcolor=red];
    }
    6 -> {7};
    7 -> {8};
    8 -> {9};
    9 -> {10};
    10 -> {11};
    11 -> {12};
    12 -> {13};
    13 -> {14};
    14 -> {15};
    15 -> {16};
    16 -> {17};
    17 -> {18};
    18 -> {19};
    19 -> {20};

}
