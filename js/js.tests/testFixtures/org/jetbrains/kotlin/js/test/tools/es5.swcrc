{
    "$schema": "https://swc.rs/schema.json",
    "jsc": {
        "parser": {
            "syntax": "ecmascript",
            "dynamicImport": true,
            "functionBind": true,
            "importMeta": true
        },
        "loose": true,
        "target": "es5"
    },
    "exclude": [".*\\.d\\.m?ts$"],
    "sourceMaps": true,
    "inputSourceMap": true
}
