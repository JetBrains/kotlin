{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    }
  },
  "patternProperties": {
    "^[A-Za-z0-9_]+$": {
      "$ref": "#/$defs/system"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "system": {
      "type": "object",
      "properties": {
        "home": {
          "type": "string"
        },
        "include": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "depends": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fullyAffectedBy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["home", "include"]
    }
  }
}
