{
    "$schema": "https://swc.rs/schema.json",
    "jsc": {
        "parser": {
            "syntax": "ecmascript",
            "dynamicImport": true,
            "functionBind": true,
            "importMeta": true
        },
    },
    "loose": true,
    "target": "es5",
    "module": {
        "resolveFully": true,
        "type": "nodenext",
        "outFileExtension": "mjs"
    },
    "exclude": [".*\\.d\\.m?ts$"],
    "sourceMaps": true,
    "inputSourceMap": true
}